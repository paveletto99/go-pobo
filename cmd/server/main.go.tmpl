package main

import (
	"context"
	"errors"
	"fmt"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"example.com/my-project/internal/routes"
	"example.com/my-project/pkg/config"
	"example.com/my-project/pkg/database"
	"example.com/my-project/pkg/observability"
	"example.com/my-project/pkg/render"
)

func main() {
	os.Exit(run())
}

func run() int {
	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	telemetry, err := observability.Setup(ctx, "server")
	if err != nil {
		fmt.Fprintln(os.Stderr, fmt.Errorf("setup observability: %w", err))
		return 1
	}
	defer func() {
		shutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()
		if err := telemetry.Shutdown(shutdownCtx); err != nil {
			fmt.Fprintln(os.Stderr, fmt.Errorf("shutdown observability: %w", err))
		}
	}()

	logger := telemetry.Logger.With("component", "cmd/server")
	if err := realMain(ctx, logger); err != nil {
		logger.ErrorContext(ctx, "server exited with error", "error", err)
		return 1
	}

	return 0
}

func realMain(ctx context.Context, logger *slog.Logger) error {
	cfg, err := config.NewServerConfig(ctx)
	if err != nil {
		return fmt.Errorf("load config: %w", err)
	}

	db, err := database.Open(ctx, cfg.DatabaseURL)
	if err != nil {
		return fmt.Errorf("open database: %w", err)
	}
	defer db.Close()

	renderer := render.New(cfg.DevMode)

	mux, err := routes.Server(ctx, cfg, db, renderer)
	if err != nil {
		return fmt.Errorf("build routes: %w", err)
	}

	logger.InfoContext(ctx, "starting server", "port", cfg.Port)

	srv := &http.Server{
		Addr:              ":" + cfg.Port,
		Handler:           mux,
		ReadHeaderTimeout: 5 * time.Second,
		IdleTimeout:       30 * time.Second,
	}

	go func() {
		<-ctx.Done()
		shutdownCtx, cancel := context.WithTimeout(context.Background(), cfg.ShutdownTimeout)
		defer cancel()
		_ = srv.Shutdown(shutdownCtx)
	}()

	err = srv.ListenAndServe()
	if err != nil && !errors.Is(err, http.ErrServerClosed) {
		return fmt.Errorf("serve http: %w", err)
	}

	logger.InfoContext(ctx, "server stopped")

	return nil
}