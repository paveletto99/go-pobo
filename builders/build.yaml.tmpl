timeout: '1200s'
options:
  machineType: 'E2_HIGHCPU_8'
  env:
  - 'GO111MODULE=on'
  - 'CGO_ENABLED=0'
  - 'GOOS=linux'
  - 'GOARCH=amd64'

substitutions:
  _GO_TAGS: ''
  _IMAGE: 'gcr.io/${PROJECT_ID}/my-project/server'
  _SERVICE: 'server'
  _TAG: 'dev'

steps:
- id: 'mkdir-bin'
  name: 'bash:5'
  args: ['mkdir', '-p', 'bin']
  waitFor: ['-']

- id: 'build'
  name: 'golang:1.19'
  entrypoint: '/bin/sh'
  args:
  - '-ceu'
  - |
    go build \
      -tags="${_GO_TAGS}" \
      -trimpath \
      -ldflags="-s -w" \
      -o "./bin/${_SERVICE}" \
      "./cmd/${_SERVICE}"
  waitFor: ['mkdir-bin']

- id: 'dockerize'
  name: 'gcr.io/cloud-builders/docker'
  args:
  - 'build'
  - '--file=builders/service.dockerfile'
  - '--tag=${_IMAGE}:${_TAG}'
  - '--build-arg=SERVICE=${_SERVICE}'
  - '.'
  waitFor: ['build']

- id: 'push'
  name: 'gcr.io/cloud-builders/docker'
  args: ['push', '${_IMAGE}:${_TAG}']
  waitFor: ['dockerize']

images:
- '${_IMAGE}:${_TAG}'