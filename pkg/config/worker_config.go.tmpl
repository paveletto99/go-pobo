package config

import (
	"context"
	"fmt"

	"github.com/sethvargo/go-envconfig"
)

type WorkerConfig struct {
	Port            string `env:"WORKER_PORT, default=8082"`
	DevMode         bool   `env:"DEV_MODE, default=false"`
	DatabaseURL     string `env:"DATABASE_URL, required"`
	ShutdownTimeout Duration `env:"SHUTDOWN_TIMEOUT, default=10s"`
}

func NewWorkerConfig(ctx context.Context) (*WorkerConfig, error) {
	var cfg WorkerConfig
	if err := envconfig.Process(ctx, &cfg); err != nil {
		return nil, fmt.Errorf("process worker env: %w", err)
	}
	if err := cfg.Validate(); err != nil {
		return nil, fmt.Errorf("validate worker config: %w", err)
	}
	return &cfg, nil
}

func (c *WorkerConfig) Validate() error {
	if c.Port == "" {
		return fmt.Errorf("worker port is required")
	}
	if c.DatabaseURL == "" {
		return fmt.Errorf("database url is required")
	}
	if c.ShutdownTimeout <= 0 {
		return fmt.Errorf("shutdown timeout must be positive")
	}
	return nil
}