package example

import (
	"net/http"
	"time"

	appcontroller "example.com/my-project/pkg/controller"
	"example.com/my-project/pkg/database"
	"example.com/my-project/pkg/pagination"
	"example.com/my-project/pkg/render"
)

type Controller struct {
	db       *database.Database
	renderer *render.Renderer
}

func New(db *database.Database, renderer *render.Renderer) *Controller {
	return &Controller{db: db, renderer: renderer}
}

func (c *Controller) HandleHealth() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if err := c.db.Ping(r.Context()); err != nil {
			_ = c.renderer.JSON(w, http.StatusServiceUnavailable, map[string]string{"status": "unhealthy"})
			return
		}
		_ = c.renderer.JSON(w, http.StatusOK, map[string]string{"status": "ok"})
	})
}

func (c *Controller) HandleShow() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		started := time.Now()
		views := 1

		if session := appcontroller.SessionFromContext(r.Context()); session != nil {
			if current, ok := session.Values["views"].(int); ok {
				views = current + 1
			}
			session.Values["views"] = views
		}

		RecordExampleRequest(time.Since(started), "ok")
		_ = c.renderer.JSON(w, http.StatusOK, map[string]interface{}{
			"message": "fill in your handler here",
			"views":   views,
		})
	})
}

func (c *Controller) HandleList() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		started := time.Now()

		params, err := pagination.FromRequest(r)
		if err != nil {
			RecordExampleRequest(time.Since(started), "bad_request")
			_ = c.renderer.JSON(w, http.StatusBadRequest, map[string]string{"error": err.Error()})
			return
		}

		RecordExampleRequest(time.Since(started), "ok")
		_ = c.renderer.JSON(w, http.StatusOK, map[string]interface{}{
			"items": []string{"first", "second"},
			"page":  params.Page,
			"limit": params.Limit,
		})
	})
}