package routes

import (
	"context"
	"net/http"

	"example.com/my-project/pkg/config"
	admincontroller "example.com/my-project/pkg/controller/admin"
	"example.com/my-project/pkg/controller/middleware"
	"example.com/my-project/pkg/database"
	"example.com/my-project/pkg/render"
	"github.com/gorilla/mux"
)

func AdminAPI(ctx context.Context, cfg *config.AdminAPIConfig, db *database.Database, renderer *render.Renderer) (http.Handler, error) {
	_ = ctx
	_ = cfg

	r := mux.NewRouter()

	r.Use(middleware.RequestID())

	// Install trace, logger, recovery, API key auth, and rate limiting here.
	controller := admincontroller.New(db, renderer)

	r.Handle("/health", controller.HandleHealth()).Methods(http.MethodGet)

	api := r.PathPrefix("/api").Subrouter()
	api.Handle("/tasks/run", controller.HandleRunTask()).Methods(http.MethodPost)

	return r, nil
}