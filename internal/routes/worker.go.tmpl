package routes

import (
	"context"
	"net/http"

	"example.com/my-project/pkg/config"
	"example.com/my-project/pkg/controller/middleware"
	workercontroller "example.com/my-project/pkg/controller/worker"
	"example.com/my-project/pkg/render"
	workerpkg "example.com/my-project/pkg/worker/example"
	"github.com/gorilla/mux"
)

func Worker(ctx context.Context, cfg *config.WorkerConfig, worker *workerpkg.Worker, renderer *render.Renderer) (http.Handler, error) {
	_ = ctx
	_ = cfg

	r := mux.NewRouter()

	r.Use(middleware.RequestID())
	r.Use(middleware.Observe("worker"))

	// Add internal auth here when the worker is not isolated by network.
	controller := workercontroller.New(worker, renderer)

	r.Handle("/health", controller.HandleHealth()).Methods(http.MethodGet)
	r.Handle("/tasks/run", controller.HandleRun()).Methods(http.MethodPost, http.MethodGet)

	return r, nil
}