package routes

import (
	"context"
	"net/http"

	"example.com/my-project/pkg/cookiestore"
	"example.com/my-project/pkg/config"
	controllerexample "example.com/my-project/pkg/controller/example"
	"example.com/my-project/pkg/controller/middleware"
	"example.com/my-project/pkg/database"
	"example.com/my-project/pkg/render"
	"github.com/gorilla/mux"
)

func Server(ctx context.Context, cfg *config.ServerConfig, db *database.Database, renderer *render.Renderer) (http.Handler, error) {
	_ = ctx

	r := mux.NewRouter()

	r.Use(middleware.RequestID())
	r.Use(middleware.Observe("server"))

	controller := controllerexample.New(db, renderer)
	store := cookiestore.New([]byte(cfg.CookieHashKey), []byte(cfg.CookieBlockKey), cfg.CookieDomain, cfg.SessionDuration, !cfg.DevMode)

	r.Handle("/health", controller.HandleHealth()).Methods(http.MethodGet)

	api := r.PathPrefix("/api").Subrouter()
	api.Use(middleware.RequireSession(store, "app-session"))
	api.Handle("/example", controller.HandleShow()).Methods(http.MethodGet)
	api.Handle("/examples", controller.HandleList()).Methods(http.MethodGet)

	return r, nil
}